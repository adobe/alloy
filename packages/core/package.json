{
  "name": "@adobe/alloy-core",
  "version": "1.1.2-beta.1",
  "description": "Adobe Experience Platform Web SDK Core",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adobe/alloy.git",
    "directory": "packages/core"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./src/index.js",
      "default": "./src/index.js"
    },
    "./types.js": {
      "types": "./src/types.js",
      "default": "./src/types.js"
    },
    "./componentMetadata.js": {
      "types": "./src/componentMetadata.js",
      "default": "./src/componentMetadata.js"
    },
    "./core/componentCreators.js": {
      "types": "./src/core/componentCreators.js",
      "default": "./src/core/componentCreators.js"
    },
    "./core/createEvent.js": {
      "default": "./src/core/createEvent.js"
    },
    "./core/config/createConfig.js": {
      "default": "./src/core/config/createConfig.js"
    },
    "./core/injectCreateResponse.js": {
      "default": "./src/core/injectCreateResponse.js"
    },
    "./utils": {
      "default": "./src/utils/index.js"
    },
    "./utils/validation": {
      "default": "./src/utils/validation/index.js"
    },
    "./utils/deepAssign.js": {
      "types": "./src/utils/deepAssign.js",
      "default": "./src/utils/deepAssign.js"
    },
    "./utils/dom": {
      "default": "./src/utils/dom/index.js"
    },
    "./utils/dom/*.js": {
      "default": "./src/utils/dom/*.js"
    },
    "./utils/request": {
      "default": "./src/utils/request/index.js"
    },
    "./utils/*.js": {
      "default": "./src/utils/*.js"
    },
    "./constants/*.js": {
      "default": "./src/constants/*.js"
    },
    "./components/EventMerge/createEventMergeId.js": {
      "types": "./src/components/EventMerge/createEventMergeId.js",
      "default": "./src/components/EventMerge/createEventMergeId.js"
    },
    "./components.json": "./components.json"
  },
  "author": "Adobe Inc.",
  "license": "Apache-2.0",
  "dependencies": {
    "@adobe/aep-rules-engine": "^3.1.1",
    "@adobe/reactor-query-string": "^2.0.0",
    "js-cookie": "3.0.5",
    "uuid": "^14.0.0"
  }
}
